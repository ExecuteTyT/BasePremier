# Скопируй этот файл в .env.local и заполни значения.
# .env.local добавлен в .gitignore — секреты не попадут в репозиторий.

# === Site ===
NEXT_PUBLIC_SITE_URL=https://basepremier.ru

# === Sanity CMS ===
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_TOKEN=                     # только если нужны drafts / write-запросы
SANITY_WEBHOOK_SECRET=            # для /api/revalidate endpoint

# === YClients ===
YCLIENTS_PARTNER_TOKEN=           # серверный (партнёрский токен)
YCLIENTS_USER_TOKEN=              # серверный (токен пользователя)
YCLIENTS_COMPANY_ID=              # серверный (ID компании/филиала)
NEXT_PUBLIC_YCLIENTS_COMPANY_ID=  # для виджета — можно публично
NEXT_PUBLIC_YCLIENTS_FORM_ID=     # для виджета — можно публично

# === Analytics ===
NEXT_PUBLIC_YM_ID=                # ID счётчика Яндекс.Метрики
NEXT_PUBLIC_YANDEX_VERIFICATION=  # код подтверждения Яндекс.Вебмастер

# === Sentry ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                # для загрузки source maps в Sentry

# === Telegram (уведомления о записях) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
